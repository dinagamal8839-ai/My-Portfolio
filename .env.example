# Optional — copy to `.env.local` only if you want EmailJS, Web3Forms, or Formspree
# instead of the built-in FormSubmit default (no keys required for FormSubmit).
# Restart `npm run dev` after changes.

# EmailJS (https://www.emailjs.com) — highest priority if set
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Web3Forms (https://web3forms.com)
VITE_WEB3FORMS_ACCESS_KEY=

# Formspree (https://formspree.io) — form ID only
VITE_FORMSPREE_FORM_ID=
